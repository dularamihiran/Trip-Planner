# MongoDB Connection
MONGODB_URI=your_mongodb_connection_string_here

# Database Name
DB_NAME=trip_planner

# Next.js Environment
NODE_ENV=development

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# AWS S3 Configuration for Image Uploads (Optional)
# Comment out if not using AWS S3
# NEXT_PUBLIC_AWS_REGION=ap-south-1
# NEXT_PUBLIC_AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
# NEXT_PUBLIC_AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
# NEXT_PUBLIC_AWS_S3_BUCKET=your_s3_bucket_name_here
